common --noenable_workspace

# Reproducible Go builds.
build --incompatible_strict_action_env

# Provide STABLE_IMAGE_COMMIT_SHA on every build so the chart (stamp = 1) always
# resolves {STABLE_IMAGE_COMMIT_SHA}. CI sets $IMAGE_COMMIT_SHA; otherwise it is
# derived from git in bazel/workspace_status.sh.
build --workspace_status_command=./bazel/workspace_status.sh

# --config=release enables --stamp (rules_img stamp attr defaults to "auto").
build:release --stamp
